*.bak
*.tmp
.tmp_*.json
*.swp
*.swo
*.zip
*.tar
*.tar.gz

# Build/package output
build/
dist/
*.egg-info/
*.spec

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
