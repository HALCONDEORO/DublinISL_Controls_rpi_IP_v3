# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and coverage output
.coverage
coverage.xml
htmlcov/
.tox/

# Logs and runtime diagnostics
logs/
*.log
audit_log.json
boot_stats.json

# Local security files - never commit real credentials
/password.enc
/password.txt
